# Copia este archivo como .env y completa los valores.

# URL de tu servidor Jellyfin, sin barra final.
JELLYFIN_URL=http://localhost:8096

# API Key de Jellyfin: Dashboard > Avanzado > Claves de API > +
JELLYFIN_API_KEY=

# Frecuencia en milisegundos con la que el navegador pide datos nuevos.
JELLYFIN_REFRESH_MS=2000

# Ruta al almacenamiento multimedia. Se usa para metricas de disco del host.
JELLYFIN_MEDIA_PATH=E:\Multimedia

# Host y puerto donde corre este monitor.
JELLYFIN_MONITOR_HOST=127.0.0.1
JELLYFIN_MONITOR_PORT=8765

# Abrir el navegador automaticamente al iniciar: 1 = si, 0 = no.
JELLYFIN_MONITOR_OPEN_BROWSER=1
